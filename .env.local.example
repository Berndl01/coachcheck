# ============================================================
# Resend — Transactional Emails
# ============================================================
RESEND_API_KEY=re_HIER_EINSETZEN
RESEND_FROM_EMAIL="Humatrix Coach <noreply@humatrix.cc>"
RESEND_REPLY_TO=office@humatrix.cc

# WICHTIG für SPAM-Vermeidung:
# 1. Resend → Domains → "humatrix.cc" hinzufügen
# 2. Folgende DNS-Records setzen (im Domain-Provider):
#    - SPF (TXT):    "v=spf1 include:_spf.resend.com ~all"
#    - DKIM (TXT):   resend._domainkey ... (Wert kommt aus Resend Dashboard)
#    - DMARC (TXT):  _dmarc → "v=DMARC1; p=quarantine; rua=mailto:office@humatrix.cc"
# 3. Domain in Resend muss "verified" Status haben (grün), bevor produktiv versendet wird
# 4. Test mit https://www.mail-tester.com — Score >= 9/10 anstreben
#
# Falls Domain (noch) nicht verifiziert: System fällt auf onboarding@resend.dev zurück.
# Diese Test-Domain kann NUR an die Resend-Account-Owner-Mail senden — externe
# Empfänger bekommen entweder gar nichts oder es landet im SPAM. Daher: erst
# Domain verifizieren, DANN Live-Tests fahren.

# Supabase Auth E-Mails (Signup-Bestätigung, Passwort-Reset):
# Resend in Supabase als SMTP konfigurieren:
#   Host: smtp.resend.com
#   Port: 465 (SSL) oder 587 (TLS)
#   Username: resend
#   Password: <RESEND_API_KEY>
#   Sender: noreply@humatrix.cc

# Optional: separate Empfänger-Mail für Kontaktformular-Anfragen
# KONTAKT_EMAIL=office@humatrix.cc

# ============================================================
# Anthropic (für Report-KI / PDF-Report)
# ============================================================
ANTHROPIC_API_KEY=sk-ant_HIER_EINSETZEN

# ============================================================
