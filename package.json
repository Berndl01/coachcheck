{
  "name": "coachcheck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "prebuild": "tsc --noEmit && node scripts/claimcheck.mjs",
    "build": "next build",
    "build:mem": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "build:verbose": "tsc --noEmit && next build 2>&1 | while IFS= read -r line; do printf '[%s] %s\\n' \"$(date +%H:%M:%S)\" \"$line\"; done",
    "start": "next start",
    "lint": "eslint .",
    "claimcheck": "node scripts/claimcheck.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:release": "playwright test tests/e2e/release-flow.spec.ts",
    "preflight": "node scripts/preflight-release.mjs",
    "release:assert-env": "node scripts/assert-release-e2e-env.mjs",
    "release:verify": "npm run ci && npm run preflight && npm run release:assert-env && npm run test:e2e:release",
    "pdftest": "node scripts/pdf-fulltest.mjs",
    "sample": "node scripts/build-sample-report.mjs",
    "ci": "tsc --noEmit && node scripts/claimcheck.mjs && vitest run && eslint .",
    "verify": "next build && tsc --noEmit && node scripts/claimcheck.mjs && vitest run && eslint . --max-warnings 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@react-pdf/renderer": "^4.1.5",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.2",
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "resend": "^4.0.1",
    "stripe": "^17.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.14"
  }
}
